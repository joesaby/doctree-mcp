# Path to your markdown repository root
DOCS_ROOT=./docs

# Comma-separated glob patterns for finding files to index
# Supports markdown, CSV, and JSONL: **/*.md,**/*.csv,**/*.jsonl
DOCS_GLOB=**/*.md

# Maximum heading depth to index (1-6)
MAX_DEPTH=6

# Characters to include in node summaries
SUMMARY_LENGTH=200

# Port for HTTP transport (server-http.ts)
PORT=3100

# Path to glossary JSON for query expansion (default: $DOCS_ROOT/glossary.json)
# GLOSSARY_PATH=./glossary.json

# Maximum characters for CSV text fields in BM25 index (full content still stored for retrieval)
# CSV_MAX_TEXT_LENGTH=2000
